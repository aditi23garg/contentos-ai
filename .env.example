# Which LLM provider to use: "groq" (default, free tier, no GPU needed) or "ollama" (local, offline)
LLM_PROVIDER=groq

# --- Groq (https://console.groq.com) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Caps response length -- prevents long fields (e.g. Brand Guardian's "reason") from
# getting truncated mid-response and producing unparseable JSON.
LLM_MAX_TOKENS=1024

# --- Ollama (fallback / offline) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# --- Brand Guardian rubric thresholds ---
RUBRIC_PASS_AVERAGE=4.0
RUBRIC_MIN_DIMENSION=3

# --- Batching: Research generates IDEAS_PER_BATCH candidates in one call; after
# dedup and in-batch near-duplicate filtering, the top BATCH_SIZE (by confidence) get
# fully produced and scored. Kept modest by default for free-tier request budgets --
# raise toward the spec's ~20/~10 once you've watched a few batches run. ---
IDEAS_PER_BATCH=8
BATCH_SIZE=5
MAX_GUARDIAN_RETRIES=1

# --- Persistence (SQLite for records, ChromaDB for idea dedup embeddings) ---
# Leave these commented out to use the default data/ paths; uncomment to override.
# DB_PATH=./data/contentos.db
# CHROMA_PERSIST_DIR=./data/chroma
# 0 = never filter as a duplicate, 1 = only filter exact duplicates
DEDUP_SIMILARITY_THRESHOLD=0.85
